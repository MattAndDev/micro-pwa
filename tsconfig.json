{
  "compilerOptions": {
    "jsx": "react",
    "jsxFactory": "h",
    "moduleResolution": "node",
    "strict": true,
    "target": "ES2017",
    "sourceMap": true,
    "esModuleInterop": true,
    "rootDir": "./",
    "baseUrl": ".",
    "paths": {
      "@server/*": [
        "./server/*"
      ],
      "@client/*": [
        "./client/*"
      ],
      "@env": [
        "env.ts"
      ]
    }
  }
}