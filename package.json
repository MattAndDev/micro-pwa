{
  "name": "micro-pwa",
  "version": "0.0.1",
  "description": "Micro pwa setup with preact, typescript, ssr and jss",
  "scripts": {
    "start": "ts-node -r tsconfig-paths/register -p ./ -w -d -h -b debug",
    "bundle": "ts-node -r tsconfig-paths/register -p ./",
    "bundle:debug": "ts-node -r tsconfig-paths/register -p ./ -b debug",
    "code:quality": "npm run prettier:write && npm run eslint:write",
    "eslint:write": "eslint --fix -c ./.eslintrc.js './{source,server,scripts,conf}/**/*.{js,ts,tsx}'",
    "prettier:write": "prettier ./.prettierrc './**/*' --write --loglevel warn"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MattAndDev/micro-pwa"
  },
  "author": "Matteo Maronati",
  "license": "WTFPL",
  "bugs": {
    "url": "https://github.com/MattAndDev/micro-pwa/issues"
  },
  "homepage": "https://github.com/MattAndDev/micro-pwa#readme",
  "dependencies": {
    "express": "^5.0.0-alpha.7",
    "express-http-proxy": "^1.6.2",
    "preact": "^10.4.7",
    "preact-router": "^3.2.1",
    "react-jss": "^10.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.11.1",
    "@babel/preset-env": "^7.11.0",
    "@types/copy-webpack-plugin": "^6.0.0",
    "@types/cors": "^2.8.7",
    "@types/express": "^4.17.7",
    "@types/express-http-proxy": "^1.6.1",
    "@types/nodemon": "^1.19.0",
    "@types/webpack": "^4.41.21",
    "@types/webpack-dev-middleware": "^3.7.1",
    "@types/webpack-env": "^1.15.2",
    "@types/webpack-merge": "^4.1.5",
    "@types/workbox-sw": "^4.3.1",
    "@types/workbox-webpack-plugin": "^5.1.4",
    "@types/yargs": "^15.0.5",
    "@typescript-eslint/eslint-plugin": "^3.9.0",
    "@typescript-eslint/parser": "^3.9.0",
    "babel-loader": "^8.1.0",
    "copy-webpack-plugin": "^6.0.3",
    "cors": "^2.8.5",
    "eslint": "^7.7.0",
    "eslint-config-prettier": "^6.11.0",
    "eslint-plugin-prettier": "^3.1.4",
    "eslint-plugin-react": "^7.20.6",
    "file-loader": "^6.0.0",
    "nodemon": "^2.0.4",
    "preact-render-to-string": "^5.1.10",
    "prettier": "^2.0.5",
    "style-loader": "^1.2.1",
    "ts-loader": "^8.0.2",
    "ts-node": "^8.10.2",
    "tsconfig-paths": "^3.9.0",
    "tsconfig-paths-webpack-plugin": "^3.3.0",
    "typescript": "^3.9.7",
    "webpack": "^4.44.1",
    "webpack-cli": "^3.3.12",
    "webpack-dev-middleware": "^3.7.2",
    "webpack-dev-server": "^3.11.0",
    "webpack-hot-middleware": "^2.25.0",
    "webpack-merge": "^5.1.1",
    "workbox-webpack-plugin": "^5.1.3",
    "yargs": "^15.4.1"
  }
}
